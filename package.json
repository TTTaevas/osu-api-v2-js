{
  "name": "osu-api-v2-js",
  "version": "1.0.5",
  "description": "Package to easily access the new api of osu!",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prepublish": "npm run build",
    "build": "tsc",
    "test": "vitest --typecheck",
    "test-authorized": "npm run build && node ./dist/tests/test_authorized.js",
    "doc": "npx typedoc lib/index.ts --cname osu-v2.taevas.xyz"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "author": "Taevas",
  "repository": {
    "type": "git",
    "url": "https://github.com/TTTaevas/osu-api-v2-js.git"
  },
  "homepage": "https://osu-v2.taevas.xyz/",
  "keywords": [
    "osu",
    "api",
    "osu-api",
    "v2",
    "wrapper",
    "api-wrapper",
    "lazer"
  ],
  "license": "WTFPL",
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/prompt-sync": "^4.2.3",
    "@types/ws": "^8.5.12",
    "dotenv": "^16.4.5",
    "prompt-sync": "^4.2.0",
    "typedoc": "^0.26.8",
    "typescript": "~5.3.2",
    "vitest": "^2.1.2"
  },
  "dependencies": {
    "node-fetch": "^3.3.2",
    "ws": "^8.18.0"
  }
}
